# Copy this file to .env and fill in your actual API keys.
# DO NOT commit .env to version control — it is excluded by .gitignore.

# === Anthropic Claude API ===
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# If using a third-party proxy, set base URL accordingly:
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# === OpenAI API (backup / cross-validation only) ===
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# === NCBI E-utilities ===
NCBI_EMAIL=your.email@example.com
NCBI_API_KEY=                              # Optional but recommended (raises rate limit to 10/sec)

# === OpenAlex (no key required; email gets you "polite pool" priority) ===
OPENALEX_EMAIL=your.email@example.com
