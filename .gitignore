secrets/
*_pat_*.txt
*_token_*.txt

# Raw data (too large, not for GitHub)
data/raw/*
!data/raw/.gitkeep

# Intermediate LLM outputs (will upload anonymized final version)
data/llm_output/raw_*
data/llm_output/temp_*

# Large pharmacology binary dumps
data/pharmacology/*.dump
data/pharmacology/*.cache

# Cytoscape sessions backups
*.cys.bak

# Backup files
*~
*.bak


# === WoS raw data ===
# Clarivate Analytics Terms of Use forbid bulk redistribution of WoS data
# Raw .txt exports stay local; reproduce via documented search strategy
data/raw/wos/*.txt
data/raw/wos_partial2026/*.txt
# Preserve directory structure with .gitkeep
!data/raw/wos/.gitkeep
!data/raw/wos_partial2026/.gitkeep
